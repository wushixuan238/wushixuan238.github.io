+# Notion API Configuration
+
+# Get your Notion API key from:
+# https://www.notion.so/my-integrations
+VITE_NOTION_API_KEY=ntn_your_notion_api_key_here
+
+# Notion Database ID
+# After creating your blog database in Notion, copy the ID from the URL:
+# https://www.notion.so/workspace/DATABASE_ID?v=VIEW_ID
+VITE_NOTION_DATABASE_ID=your_database_id_here
